# ============================================
# HYNTRIX AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# ============================================

# ============================================
# SUPABASE (Database + Auth)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=https://hyntrixai.com
NODE_ENV=development

# ============================================
# AI PROVIDER — GEMINI (PRIMARY)
# Get free key at: https://aistudio.google.com/apikey
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# ============================================
# SOCIAL INTELLIGENCE — APIFY (for all platforms)
# Get free key at: https://console.apify.com/
# Used by: Instagram, YouTube, X, Telegram, Facebook
# ============================================
APIFY_API_KEY=your_apify_api_key_here

# ============================================
# AI PROVIDERS — FUTURE (Optional)
# ============================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# PAYMENTS (Razorpay)
# Get keys at: https://dashboard.razorpay.com/app/keys
# ============================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id