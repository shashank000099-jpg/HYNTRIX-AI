# HYNTRIX AI - Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# Never share these keys with anyone

# ============================================
# AUTHENTICATION & DATABASE
# ============================================

# Supabase Configuration - Get from Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# AI & CONTENT GENERATION
# ============================================

# Google Gemini API (for startup analysis, founder DNA)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API (for advanced analysis)
# Get from: https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# SOCIAL MEDIA & DATA
# ============================================

# YouTube Data API (for YouTube analysis)
# Get from: https://console.developers.google.com/
YOUTUBE_API_KEY=your-youtube-api-key-here

# Apify API (for social media scraping)
# Get from: https://apify.com/
APIFY_API_KEY=your-apify-api-key-here

# ============================================
# PAYMENTS
# ============================================

# Razorpay (for Indian payments)
# Get from: https://dashboard.razorpay.com/
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_SECRET_KEY=your-razorpay-secret-key

# ============================================
# APPLICATION
# ============================================

# Next.js environment
NODE_ENV=development

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SECURITY (DO NOT SHARE)
# ============================================

# Session secret - Generate a random 32+ character string
SESSION_SECRET=your-random-secret-key-min-32-characters

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
